{
  "name": "drill4j.github.io",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "npm run tailwind:css && docusaurus start",
    "build": "set NODE_ENV=production&& npm run tailwind:css && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "tailwind:css": "npx tailwindcss -i src/css/tailwind.css -c tailwind.config.js -o src/css/index.css"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/plugin-google-tag-manager": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@mdx-js/react": "^3.1.0",
    "clsx": "^2.1.0",
    "docusaurus-plugin-sass": "^0.2.6",
    "hast-util-is-element": "^3.0.0",
    "mermaid": "^10.1.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-image-lightbox": "^5.1.4",
    "react-rellax-wrapper": "^1.0.6",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "uuid": "^8.3.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/tsconfig": "3.9.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "docusaurus-plugin-module-alias": "0.0.2",
    "postcss": "^8.4.0",
    "sass": "^1.71.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  }
}
